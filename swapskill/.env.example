# SwapSkill Environment Configuration Template
# Copy this file to .env and update with your actual values

# =============================================================================
# DJANGO CONFIGURATION
# =============================================================================

# Secret key for Django (generate a new one for production)
# You can generate one at: https://djecrety.ir/
SECRET_KEY=your-super-secret-key-here-make-it-long-and-random-change-this-in-production

# Debug mode (set to False in production)
DEBUG=True

# Allowed hosts (comma-separated list)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database URL
# Development (SQLite): sqlite:///db.sqlite3
# Production (PostgreSQL): postgresql://user:password@host:port/database
DATABASE_URL=sqlite:///db.sqlite3

# =============================================================================
# CACHE CONFIGURATION
# =============================================================================

# Redis URL for caching and sessions
# Development: redis://localhost:6379/0
# Production: redis://redis-server:6379/0
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Email backend
# Development: django.core.mail.backends.console.EmailBackend
# Production: django.core.mail.backends.smtp.EmailBackend
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP Configuration (for production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-specific-password

# Default from email
DEFAULT_FROM_EMAIL=SwapSkill <noreply@swapskill.com>

# =============================================================================
# VOICE AI INTEGRATION
# =============================================================================

# Ultravox API Configuration
ULTRAVOX_API_KEY=your-ultravox-api-key-here
ULTRAVOX_BASE_URL=https://api.ultravox.ai

# Twilio Configuration
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Voice AI Features
ENABLE_VOICE_AI=True

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True

# CSRF Configuration
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Security Headers (set to True in production with HTTPS)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# =============================================================================
# FILE STORAGE CONFIGURATION
# =============================================================================

# Use AWS S3 for file storage (set to True for production)
USE_S3=False

# AWS S3 Configuration (for production)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
AWS_S3_REGION_NAME=us-west-2
AWS_S3_CUSTOM_DOMAIN=your-cloudfront-domain.cloudfront.net

# Local file storage paths (for development)
MEDIA_ROOT=media/
STATIC_ROOT=staticfiles/

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log file path (leave empty to disable file logging)
LOG_FILE_PATH=logs/

# Sentry DSN for error tracking (optional)
SENTRY_DSN=your-sentry-dsn-here

# =============================================================================
# PERFORMANCE CONFIGURATION
# =============================================================================

# Cache timeout in seconds
CACHE_TIMEOUT=300

# Session configuration
SESSION_COOKIE_AGE=86400
SESSION_EXPIRE_AT_BROWSER_CLOSE=False

# Database connection pooling
DB_CONN_MAX_AGE=60

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable/disable features
ENABLE_REAL_TIME_CHAT=True
ENABLE_EMAIL_NOTIFICATIONS=True
ENABLE_PUSH_NOTIFICATIONS=False
ENABLE_ANALYTICS=True

# =============================================================================
# THIRD-PARTY INTEGRATIONS
# =============================================================================

# Google Analytics (optional)
GOOGLE_ANALYTICS_ID=your-google-analytics-id

# Facebook App ID (optional)
FACEBOOK_APP_ID=your-facebook-app-id

# Google OAuth (optional)
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret

# =============================================================================
# DEVELOPMENT CONFIGURATION
# =============================================================================

# Django Debug Toolbar (development only)
ENABLE_DEBUG_TOOLBAR=True

# Django Extensions (development only)
ENABLE_DJANGO_EXTENSIONS=True

# =============================================================================
# PRODUCTION CONFIGURATION
# =============================================================================

# Production-specific settings (uncomment for production)
# DEBUG=False
# ALLOWED_HOSTS=your-domain.com,www.your-domain.com
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
# SECURE_CONTENT_TYPE_NOSNIFF=True
# SECURE_BROWSER_XSS_FILTER=True
# X_FRAME_OPTIONS=DENY

# =============================================================================
# DOCKER CONFIGURATION
# =============================================================================

# Docker-specific environment variables
DOCKER_ENV=False

# Database host for Docker
DB_HOST=db
DB_PORT=5432

# Redis host for Docker
REDIS_HOST=redis
REDIS_PORT=6379

# =============================================================================
# MONITORING & ANALYTICS
# =============================================================================

# Application monitoring
ENABLE_HEALTH_CHECKS=True
HEALTH_CHECK_ACCESS_TOKEN=your-health-check-token

# Performance monitoring
ENABLE_PERFORMANCE_MONITORING=True

# User analytics
ENABLE_USER_ANALYTICS=True

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================

# Backup settings
BACKUP_ENABLED=True
BACKUP_STORAGE=local
BACKUP_RETENTION_DAYS=30

# S3 backup configuration (if using S3 for backups)
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_PREFIX=swapskill-backups/

# =============================================================================
# CELERY CONFIGURATION (for background tasks)
# =============================================================================

# Celery broker URL
CELERY_BROKER_URL=redis://localhost:6379/0

# Celery result backend
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Celery timezone
CELERY_TIMEZONE=UTC

# =============================================================================
# WEBSOCKET CONFIGURATION
# =============================================================================

# WebSocket settings
WEBSOCKET_ENABLED=True
WEBSOCKET_URL=ws://localhost:8000/ws/

# Channel layers (for Django Channels)
CHANNEL_LAYERS_BACKEND=channels_redis.core.RedisChannelLayer
CHANNEL_LAYERS_CONFIG_HOSTS=redis://localhost:6379/1

# =============================================================================
# API CONFIGURATION
# =============================================================================

# API rate limiting
API_RATE_LIMIT_ANON=100/hour
API_RATE_LIMIT_USER=1000/hour

# API pagination
API_PAGE_SIZE=20
API_MAX_PAGE_SIZE=100

# JWT token settings
JWT_ACCESS_TOKEN_LIFETIME=60  # minutes
JWT_REFRESH_TOKEN_LIFETIME=7  # days

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# API URL (for frontend to connect to backend)
REACT_APP_API_URL=http://localhost:8000/api
REACT_APP_WS_URL=ws://localhost:8000/ws
REACT_APP_VOICE_AI_URL=http://localhost:8000/api/voice-ai

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================

# Test database
TEST_DATABASE_URL=sqlite:///test_db.sqlite3

# Test settings
TESTING=False
SKIP_MIGRATIONS=False

# =============================================================================
# NOTES
# =============================================================================

# 1. Never commit this file with real credentials to version control
# 2. Use strong, unique passwords for all services
# 3. Regularly rotate API keys and secrets
# 4. Use environment-specific values for different deployment stages
# 5. Consider using a secrets management service for production
# 6. Validate all environment variables on application startup
