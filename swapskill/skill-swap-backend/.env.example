# SkillSwap Environment Variables
# Copy this file to .env and fill in your actual values

# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True

# Database (if using PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/skillswap

# Google OAuth2 Credentials
# Get these from: https://console.developers.google.com/
GOOGLE_OAUTH2_KEY=your-google-client-id
GOOGLE_OAUTH2_SECRET=your-google-client-secret

# Facebook OAuth Credentials  
# Get these from: https://developers.facebook.com/
FACEBOOK_KEY=your-facebook-app-id
FACEBOOK_SECRET=your-facebook-app-secret

# GitHub OAuth Credentials
# Get these from: https://github.com/settings/applications/new
GITHUB_KEY=your-github-client-id
GITHUB_SECRET=your-github-client-secret

# Email Settings (Gmail SMTP - Recommended)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=noreply@skillswap.com

# Alternative Email Providers:
# For Outlook/Hotmail:
# EMAIL_HOST_USER=your-email@outlook.com
# EMAIL_HOST_PASSWORD=your-outlook-password

# For SendGrid:
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key

# Redis (for production caching and channels)
REDIS_URL=redis://localhost:6379/0

# Allowed Hosts (for production)
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Voice AI - Twilio
# Get these from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Voice AI - Ultravox
# Get your API key from: https://ultravox.ai
ULTRAVOX_API_KEY=your-ultravox-api-key
VOICE_AI_SERVICE_URL=http://localhost:3002

# Base URL for webhooks (needed for production)
BASE_URL=http://127.0.0.1:8000
